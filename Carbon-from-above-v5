<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Carbon From Above — Solbakken Research Initiative</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Mono:wght@300;400&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
–bg: #0a0c0f;
–surface: #111318;
–border: #1e2229;
–accent: #c8a96e;
–accent-dim: #7a6340;
–text: #d4cfc8;
–text-dim: #6b6660;
–text-bright: #ede8e0;
–mono: ‘DM Mono’, monospace;
–serif: ‘Playfair Display’, serif;
–body: ‘Cormorant Garamond’, serif;
}

html { scroll-behavior: smooth; }

body {
background: var(–bg);
color: var(–text);
font-family: var(–body);
font-size: 17px;
line-height: 1.75;
min-height: 100vh;
}

/* HEADER */
header {
border-bottom: 1px solid var(–border);
padding: 3rem 0 2.5rem;
position: relative;
overflow: hidden;
}

header::before {
content: ‘’;
position: absolute;
top: -60px; right: -80px;
width: 400px; height: 400px;
background: radial-gradient(circle, rgba(200,169,110,0.06) 0%, transparent 70%);
pointer-events: none;
}

.header-inner {
max-width: 820px;
margin: 0 auto;
padding: 0 2.5rem;
}

.meta-line {
font-family: var(–mono);
font-size: 0.68rem;
letter-spacing: 0.18em;
color: var(–accent-dim);
text-transform: uppercase;
margin-bottom: 1.6rem;
}

.meta-line span { color: var(–accent); }

h1 {
font-family: var(–serif);
font-size: clamp(2rem, 5vw, 3.2rem);
font-weight: 700;
color: var(–text-bright);
line-height: 1.15;
letter-spacing: -0.01em;
margin-bottom: 0.5rem;
}

.subtitle {
font-family: var(–serif);
font-style: italic;
font-size: 1.05rem;
color: var(–text-dim);
margin-bottom: 2rem;
}

.tag-row {
display: flex;
gap: 0.6rem;
flex-wrap: wrap;
}

.tag {
font-family: var(–mono);
font-size: 0.62rem;
letter-spacing: 0.12em;
text-transform: uppercase;
padding: 0.28rem 0.7rem;
border: 1px solid var(–border);
color: var(–text-dim);
}

.tag.speculative { border-color: var(–accent-dim); color: var(–accent); }

/* MAIN LAYOUT */
main {
max-width: 820px;
margin: 0 auto;
padding: 0 2.5rem 6rem;
}

/* ABSTRACT */
.abstract {
margin: 3rem 0;
padding: 2rem 2.5rem;
border-left: 2px solid var(–accent);
background: var(–surface);
}

.abstract .section-label {
margin-bottom: 0.8rem;
}

.abstract p {
font-size: 1.08rem;
line-height: 1.8;
color: var(–text-bright);
}

/* SECTION */
section { margin: 3.5rem 0; }

.section-label {
font-family: var(–mono);
font-size: 0.62rem;
letter-spacing: 0.2em;
text-transform: uppercase;
color: var(–accent);
margin-bottom: 1rem;
display: flex;
align-items: center;
gap: 0.8rem;
}

.section-label::after {
content: ‘’;
flex: 1;
height: 1px;
background: var(–border);
}

h2 {
font-family: var(–serif);
font-size: 1.7rem;
font-weight: 700;
color: var(–text-bright);
margin-bottom: 1.2rem;
line-height: 1.2;
}

h3 {
font-family: var(–serif);
font-size: 1.15rem;
font-weight: 400;
font-style: italic;
color: var(–accent);
margin: 1.8rem 0 0.7rem;
}

p { margin-bottom: 1rem; }

/* TABLES */
.table-wrap {
overflow-x: auto;
margin: 1.5rem 0;
}

table {
width: 100%;
border-collapse: collapse;
font-family: var(–mono);
font-size: 0.78rem;
}

thead tr {
border-bottom: 1px solid var(–accent-dim);
}

th {
text-align: left;
padding: 0.6rem 1rem;
letter-spacing: 0.1em;
text-transform: uppercase;
color: var(–accent);
font-weight: 400;
}

td {
padding: 0.55rem 1rem;
color: var(–text);
border-bottom: 1px solid var(–border);
vertical-align: top;
}

tr:last-child td { border-bottom: none; }

tr:hover td { background: rgba(200,169,110,0.03); }

/* PHASE CARDS */
.phase-grid {
display: grid;
grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
gap: 1px;
background: var(–border);
margin: 1.5rem 0;
}

.phase-card {
background: var(–surface);
padding: 1.5rem;
}

.phase-num {
font-family: var(–mono);
font-size: 0.6rem;
letter-spacing: 0.2em;
text-transform: uppercase;
color: var(–accent-dim);
margin-bottom: 0.4rem;
}

.phase-title {
font-family: var(–serif);
font-size: 1.05rem;
color: var(–text-bright);
margin-bottom: 0.3rem;
}

.phase-years {
font-family: var(–mono);
font-size: 0.65rem;
color: var(–text-dim);
margin-bottom: 1rem;
}

.phase-items {
list-style: none;
font-size: 0.82rem;
line-height: 1.6;
color: var(–text-dim);
}

.phase-items li {
padding: 0.25rem 0;
border-top: 1px solid var(–border);
}

.phase-items li:first-child { border-top: none; }

.phase-milestone {
font-family: var(–mono);
font-size: 0.62rem;
letter-spacing: 0.08em;
color: var(–accent);
margin-top: 1rem;
padding-top: 0.8rem;
border-top: 1px solid var(–accent-dim);
}

/* FLOW DIAGRAM */
.flow {
margin: 1.5rem 0;
font-family: var(–mono);
font-size: 0.75rem;
}

.flow-step {
display: flex;
align-items: flex-start;
gap: 1rem;
padding: 0.9rem 1.2rem;
border-left: 2px solid var(–border);
margin-left: 0.5rem;
position: relative;
}

.flow-step::before {
content: ‘’;
position: absolute;
left: -5px; top: 50%;
transform: translateY(-50%);
width: 8px; height: 8px;
border: 1px solid var(–accent-dim);
background: var(–bg);
}

.flow-step.highlight {
border-left-color: var(–accent);
}

.flow-step.highlight::before {
border-color: var(–accent);
background: var(–accent);
}

.flow-node {
color: var(–text-bright);
font-weight: 400;
min-width: 180px;
}

.flow-detail {
color: var(–text-dim);
font-size: 0.68rem;
padding-top: 0.05rem;
}

/* RISK ITEMS */
.risk-item {
display: grid;
grid-template-columns: 120px 1fr auto;
gap: 1rem;
padding: 0.8rem 0;
border-bottom: 1px solid var(–border);
align-items: start;
font-size: 0.85rem;
}

.risk-item:last-child { border-bottom: none; }

.risk-domain {
font-family: var(–mono);
font-size: 0.65rem;
letter-spacing: 0.1em;
text-transform: uppercase;
color: var(–accent-dim);
padding-top: 0.1rem;
}

.risk-mode { color: var(–text); }

.risk-phase {
font-family: var(–mono);
font-size: 0.62rem;
color: var(–text-dim);
white-space: nowrap;
text-align: right;
}

.risk-phase.kill {
color: #b05a5a;
}

.risk-test {
font-size: 0.78rem;
color: var(–text-dim);
font-style: italic;
}

/* CHALLENGES */
.challenge-list {
list-style: none;
margin: 1rem 0;
}

.challenge-list li {
padding: 0.7rem 0 0.7rem 1.5rem;
border-bottom: 1px solid var(–border);
position: relative;
font-size: 0.92rem;
}

.challenge-list li::before {
content: ‘→’;
position: absolute;
left: 0;
color: var(–accent-dim);
font-family: var(–mono);
}

.challenge-list li:last-child { border-bottom: none; }

/* REFS */
.refs {
font-family: var(–mono);
font-size: 0.7rem;
color: var(–text-dim);
line-height: 1.9;
}

.refs li { margin-bottom: 0.2rem; }

/* FOOTER */
footer {
border-top: 1px solid var(–border);
padding: 2rem 2.5rem;
max-width: 820px;
margin: 0 auto;
font-family: var(–mono);
font-size: 0.62rem;
letter-spacing: 0.1em;
color: var(–text-dim);
display: flex;
justify-content: space-between;
flex-wrap: wrap;
gap: 0.5rem;
}

/* ANIMATIONS */
@keyframes fadeUp {
from { opacity: 0; transform: translateY(16px); }
to   { opacity: 1; transform: translateY(0); }
}

header { animation: fadeUp 0.6s ease both; }
.abstract { animation: fadeUp 0.6s 0.1s ease both; }
section { animation: fadeUp 0.5s 0.15s ease both; }
</style>

</head>
